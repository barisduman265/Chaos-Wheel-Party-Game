# Copy this file to android/key.properties and fill in your release keystore
# details. key.properties is gitignored and must never be committed.
#
# Generate a keystore (once) with:
#   keytool -genkey -v -keystore upload-keystore.jks -keyalg RSA \
#     -keysize 2048 -validity 10000 -alias upload
#
# storeFile may be an absolute path or relative to the android/ directory.

storePassword=CHANGE_ME
keyPassword=CHANGE_ME
keyAlias=upload
storeFile=upload-keystore.jks
